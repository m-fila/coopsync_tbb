libdir=@libdir_for_pc_file@
includedir=@includedir_for_pc_file@

Name: CoopSync_TBB
Description: Cooperative synchronization primitives for TBB resumable tasks
Version: @COOPSYNC_TBB_VERSION@

Requires: tbb
Libs: -L${libdir} -lcoopsync_tbb
Cflags: -I${includedir}